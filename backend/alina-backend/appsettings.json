{
  "RSA_PRIVATE_KEY_PATH": "keys/private_key.pem",
  "Google": {
    "WebClientId": "${GOOGLE_WEB_CLIENT_ID}",
    "ClientSecret": "${GOOGLE_CLIENT_SECRET}",
    "IosClientId": "YOUR_IOS_CLIENT_ID.apps.googleusercontent.com",
    "AndroidClientId": "YOUR_ANDROID_CLIENT_ID.apps.googleusercontent.com"
  },
  "AppSettings": {
    "BaseUrl": "http://0.0.0.0:5602"
  },
  "ConnectionStrings": {
    "DefaultConnection": "${DATABASE_CONNECTION_STRING}"
  },
  "Jwt": {
    "Issuer": "alina-backend",
    "Audience": "alina-client",
    "ExpiryHours": 1
  },
  "RateLimit": {
    "RequestsPerWindow": 100,
    "WindowMinutes": 1,
    "BlockMinutes": 15
  },
  "Email": {
    "SmtpHost": "smtp.gmail.com",
    "SmtpPort": 587,
    "Username": "${EMAIL_USERNAME}",
    "Password": "${EMAIL_PASSWORD}",
    "FromEmail": "noreply@alina.com",
    "FromName": "Alina Marketplace"
  },
  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://0.0.0.0:5602"
      }
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "alina_backend.app.auth": "Information"
    }
  },
  "AWS": {
    "AccessKeyId": "${AWS_ACCESS_KEY_ID}",
    "SecretAccessKey": "${AWS_SECRET_ACCESS_KEY}",
    "Region": "me-central-1",
    "BucketName": "aqlaan"
  },
  "AllowedHosts": "*"
}