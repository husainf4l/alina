{
  "$schema": "https://json.schemastore.org/appsettings.json",
  "RSA_PRIVATE_KEY_PATH": "/secure/keys/private_key.pem",
  "Google": {
    "WebClientId": "production-web-client-id.apps.googleusercontent.com",
    "ClientSecret": "production-client-secret",
    "IosClientId": "production-ios-client-id.apps.googleusercontent.com",
    "AndroidClientId": "production-android-client-id.apps.googleusercontent.com"
  },
  "AppSettings": {
    "BaseUrl": "https://api.alina.com"
  },
  "ConnectionStrings": {
    "DefaultConnection": "Host=production-db.alina.com;Database=alina_production;Username=alina_prod;Password=REPLACE_WITH_ENV;SslMode=Require"
  },
  "Jwt": {
    "Issuer": "alina-backend-prod",
    "Audience": "alina-client-prod",
    "ExpiryHours": 1
  },
  "RateLimit": {
    "RequestsPerWindow": 100,
    "WindowMinutes": 1,
    "BlockMinutes": 15
  },
  "Email": {
    "_comment": "Use environment variables for sensitive data in production",
    "SmtpHost": "smtp.sendgrid.net",
    "SmtpPort": 587,
    "Username": "apikey",
    "Password": "REPLACE_WITH_ENV",
    "FromEmail": "noreply@alina.com",
    "FromName": "Alina Marketplace"
  },
  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://0.0.0.0:5602"
      },
      "Https": {
        "Url": "https://0.0.0.0:5603",
        "Certificate": {
          "Path": "/secure/certs/alina.pfx",
          "Password": "REPLACE_WITH_ENV"
        }
      }
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft.AspNetCore": "Warning",
      "alina_backend": "Information"
    },
    "Console": {
      "IncludeScopes": false
    },
    "File": {
      "Path": "/var/log/alina/backend-.log",
      "RollingInterval": "Day",
      "RetainedFileCountLimit": 30
    }
  },
  "AWS": {
    "AccessKeyId": "REPLACE_WITH_ENV",
    "SecretAccessKey": "REPLACE_WITH_ENV",
    "Region": "me-central-1",
    "BucketName": "alina-production"
  },
  "Sentry": {
    "Dsn": "https://xxx@xxx.ingest.sentry.io/xxx",
    "Environment": "production",
    "TracesSampleRate": 0.1
  },
  "AllowedHosts": "alina.com;www.alina.com;api.alina.com",
  "CorsOrigins": [
    "https://alina.com",
    "https://www.alina.com",
    "https://app.alina.com"
  ]
}
